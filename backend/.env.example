PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

DB_HOST=localhost
DB_PORT=5433
DB_NAME=repota_db
DB_USER=postgres
DB_PASSWORD=postgres

JWT_SECRET=repota_development_secret
JWT_EXPIRES_IN=1d

# WAJIB DIISI agar OTP benar-benar masuk ke Gmail/email mahasiswa.
# Pakai akun Gmail pengirim milik prodi/tim, lalu buat Google App Password.
# SMTP_USER = Gmail pengirim, bukan email mahasiswa.
# SMTP_PASS = 16 digit App Password dari Google Account, bukan password login biasa.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=RepoTA <emailpengirim@gmail.com>
