PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

# Pilih salah satu:
# 1) Database Docker lokal sesuai docker-compose.yml:
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/repota_db
DB_SSL=false

# 2) Database Supabase Session Pooler, contoh:
# DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres
# DB_SSL=true

JWT_SECRET=ganti_dengan_secret_panjang_dan_aman
JWT_EXPIRES_IN=1d

UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=email_kamu@gmail.com
SMTP_PASS=app_password_gmail
MAIL_FROM=RepoTA <email_kamu@gmail.com>

SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=service_role_key_kamu
SUPABASE_STORAGE_BUCKET=repota-documents
